# Ghost Tribunal — Environment Configuration

# Required: OpenRouter API key for AI agent inference
OPENROUTER_API_KEY=sk-or-...

# Required: Private key for the tribunal wallet (on-chain verdicts)
TRIBUNAL_PRIVATE_KEY=0x...

# Network (testnet or mainnet)
XLAYER_NETWORK=testnet
XLAYER_RPC=https://testrpc.xlayer.tech

# AI model (default: google/gemini-2.5-flash — ~$0.001/session)
AGENT_MODEL=google/gemini-2.5-flash

# x402 payment (set TRIBUNAL_FREE_MODE=1 to skip payments for demos)
TRIBUNAL_FREE_MODE=1
X402_FACILITATOR_URL=https://facilitator.codenut.ai

# Optional: OKX OnchainOS API keys for enhanced token data
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Optional: Discord webhook for posting results
DISCORD_WEBHOOK=
